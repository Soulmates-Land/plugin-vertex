{
  "name": "@elizaos/plugin-vertex",
  "version": "0.3.0",
  "description": "Google Vertex AI plugin for ElizaOS — Claude models via GCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^4.0.0",
    "ai": "^6.0.23"
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-alpha.33",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=2.0.0-alpha.30"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "GOOGLE_VERTEX_PROJECT_ID": {
        "type": "string",
        "description": "Google Cloud project ID with Vertex AI API enabled",
        "required": true
      },
      "GOOGLE_VERTEX_REGION": {
        "type": "string",
        "description": "Vertex AI region (e.g. us-east5, europe-west1)",
        "default": "us-east5",
        "required": false
      },
      "VERTEX_SMALL_MODEL": {
        "type": "string",
        "description": "Claude model for TEXT_SMALL",
        "default": "claude-haiku-4-5",
        "required": false
      },
      "VERTEX_LARGE_MODEL": {
        "type": "string",
        "description": "Claude model for TEXT_LARGE",
        "default": "claude-sonnet-4-6",
        "required": false
      },
      "VERTEX_REASONING_SMALL_MODEL": {
        "type": "string",
        "description": "Claude model for TEXT_REASONING_SMALL",
        "default": "claude-sonnet-4-6",
        "required": false
      },
      "VERTEX_REASONING_LARGE_MODEL": {
        "type": "string",
        "description": "Claude model for TEXT_REASONING_LARGE",
        "default": "claude-opus-4-6",
        "required": false
      }
    }
  },
  "license": "MIT",
  "keywords": ["elizaos", "plugin", "vertex-ai", "google-cloud", "claude", "anthropic"]
}
